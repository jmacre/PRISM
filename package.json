{
  "name": "prism-game",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5199",
    "build": "vite build",
    "preview": "vite preview",
    "sync": "cap sync android",
    "apk:gradle": "cd android && .\\gradlew.bat assembleDebug",
    "apk:copy": "node -e \"const fs=require('fs'),path=require('path');const src=path.resolve('android/app/build/outputs/apk/debug/app-debug.apk');const dst=path.resolve('PRISM-Game.apk');fs.copyFileSync(src,dst);console.log('APK copied to:',dst)\"",
    "apk": "npm run build && npm run sync && npm run apk:gradle && npm run apk:copy"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite": "^5.4.0"
  }
}
